{
  "schema_version": 1,
  "suite_id": "sprint-supervisor-judgment-static",
  "skill_name": "sprint-supervisor",
  "skill_version": "1.1.0",
  "runtime_targets": [
    "Codex CLI",
    "Claude Code",
    "Gemini CLI"
  ],
  "description": "Static regression fixtures for operational judgment decisions in sprint-supervisor. Refs #162.",
  "archive_notes": [
    "This suite checks archived pane-tail scenarios and expected decision notes without calling a model or live tmux.",
    "A pass means the fixture library documents the intended judgment surface; it is not a claim of live operational safety."
  ],
  "cases": [
    {
      "id": "approve-benign-command",
      "title": "Benign read-only command approval stays routine",
      "skill_name": "sprint-supervisor",
      "runtime_targets": [
        "Codex CLI"
      ],
      "prompt_fixture": "A grid pane asks whether to run gh pr view for PR context while supervising a sprint.",
      "expected_mode": "routine approval",
      "expected_artifacts": [
        "capture-pane tail",
        "expected decision"
      ],
      "candidate": {
        "kind": "local_artifact",
        "path": "docs/benchmarks/fixtures/sprint-supervisor-judgment/approve-benign-command"
      },
      "watch_points": [
        "Rubric row coverage",
        "Read-only command classification",
        "No user escalation for routine work"
      ],
      "assertions": [
        {
          "id": "capture-present",
          "kind": "file_exists",
          "path": "capture.txt"
        },
        {
          "id": "decision-present",
          "kind": "file_exists",
          "path": "expected-decision.md"
        },
        {
          "id": "approves-read-only-command",
          "kind": "contains_all",
          "path": "expected-decision.md",
          "terms": [
            "Action: approve",
            "read-only command",
            "p Enter"
          ]
        },
        {
          "id": "does-not-escalate-routine-case",
          "kind": "not_contains_any",
          "path": "expected-decision.md",
          "terms": [
            "PushNotification",
            "pause the loop"
          ]
        }
      ]
    },
    {
