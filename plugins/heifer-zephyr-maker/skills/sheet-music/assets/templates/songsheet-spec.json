{
  "_comment": "Template for the songsheet-spec.json that build_songsheet_pdf.py --via adobe sends to the Adobe Creative Cloud Claude connector. Field meanings are documented in references/adobe-handoff.md.",
  "title": "{{title}}",
  "subtitle": "Arranged for {{instrument_display}}",
  "tempo": "{{tempo}}",
  "key": "{{key}}",
  "meter": "{{meter}}",
  "sections": [
    { "type": "title-block" },
    { "type": "meta-line",      "fields": ["key", "meter", "tempo"] },
    { "type": "notation",       "src": "tune.svg",            "height_in": 3.0 },
    { "type": "fingering-strip","src": "tune-fingering.svg",  "height_in": 1.5 },
    { "type": "practice-tip",   "src": "notes.md",            "section": "Practice tip" },
    { "type": "footer",         "wordmark": "brand-assets/heifer-zephyr-wordmark.svg",
                                "credit": "Generated by sheet-music · github.com/tonykoop/sheet-music · MIT" }
  ],
  "brand": {
    "wordmark": "brand-assets/heifer-zephyr-wordmark.svg",
    "headline_font": "Fraunces",
    "headline_weight": 600,
    "body_font": "Inter",
    "body_weight": 400,
    "mono_font": "JetBrains Mono",
    "primary_color": "#2A2A2A",
    "accent_color": "#8C5A2B"
  },
  "page_size": "letter",
  "margin_in": 0.75
}
